{
  "name": "lambda-order-state-machine",
  "version": "1.0.0",
  "author": "Thomas Do (tung-dnt)",
  "license": "MIT",
  "description": "Complete AWS Lambda example using nestjs-serverless-workflow with Durable Execution and DynamoDB",
  "type": "module",
  "main": "dist/lambda.js",
  "scripts": {
    "build": "NODE_ENV=production bun run scripts/build.ts",
    "synth": "bun run build && bunx cdk synth",
    "deploy": "bun run build && bunx cdk deploy",
    "deploy:dev": "bun run build && bunx cdk deploy -c stage=dev",
    "deploy:prod": "bun run build && bunx cdk deploy -c stage=prod",
    "diff": "bun run build && bunx cdk diff",
    "destroy": "bunx cdk destroy",
    "start": "bun run src/main.ts",
    "start:dev": "bun --hot src/main.ts",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.958.0",
    "@aws-sdk/lib-dynamodb": "^3.958.0",
    "@aws/durable-execution-sdk-js": "^1.1.0",
    "@nestjs/common": "^11.1.10",
    "@nestjs/core": "^11.1.10",
    "@nestjs/platform-express": "^11.1.10",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dynamodb-toolbox": "^2.7.4",
    "nestjs-serverless-workflow": "^0.0.8",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuidv7": "^1.1.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.159",
    "@types/bun": "^1.3.5",
    "@typescript/native-preview": "^7.0.0-dev.20251226.1",
    "aws-cdk-lib": "^2.180.0",
    "constructs": "^10.4.0",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "@nestjs/core"
  ],
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.3.4"
  },
  "keywords": [
    "nestjs",
    "serverless",
    "workflow",
    "state-machine",
    "lambda",
    "durable-execution",
    "dynamodb",
    "aws"
  ]
}
